// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("TENANT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  landlord  Landlord?
  tenant    Tenant?
  posts     Post[]
  likes     Like[]
  comments  Comment[]
  shares    Share[]
}

model Landlord {
  id        String     @id @default(cuid())
  userId    String     @unique
  userCode  String     @unique // LL001, LL002, etc.
  phone     String
  address   String?
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  buildings Building[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Building {
  id               String   @id @default(cuid())
  landlordId       String
  name             String
  address          String
  description      String?
  electricityPrice Float    @default(3000)  // VNĐ/kWh
  waterPrice       Float    @default(50000) // VNĐ/tháng
  landlord         Landlord @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  rooms            Room[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([landlordId])
}

model Room {
  id          String     @id @default(cuid())
  buildingId  String
  roomNumber  String
  floor       Int        @default(1)
  area        Float
  price       Float
  deposit     Float      @default(0)
  description String?
  status      String     @default("AVAILABLE")
  building    Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant      Tenant?
  contracts   Contract[]
  maintenanceRequests MaintenanceRequest[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@unique([buildingId, roomNumber])
  @@index([buildingId])
  @@index([status])
}

model Tenant {
  id          String     @id @default(cuid())
  userId      String     @unique
  userCode    String     @unique // TN001, TN002, etc.
  landlordId  String     @default("")
  invitationStatus String @default("none") // none, pending, accepted, rejected
  pendingRoomId String?  // Room ID in pending invitation
  phone       String
  idCard      String?
  address     String?
  roomId      String?    @unique
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        Room?      @relation(fields: [roomId], references: [id])
  contracts   Contract[]
  invoices    Invoice[]
  notifications Notification[]
  maintenanceRequests MaintenanceRequest[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([landlordId])
  @@index([roomId])
}

model Contract {
  id            String    @id @default(cuid())
  roomId        String
  tenantId      String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Float
  depositAmount Float     @default(0)
  terms         String?
  status        String    @default("ACTIVE")
  room          Room      @relation(fields: [roomId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([roomId])
  @@index([tenantId])
  @@index([status])
}

model Invoice {
  id                String    @id @default(cuid())
  tenantId          String
  month             Int
  year              Int
  rentAmount        Float
  electricityUsage  Float     @default(0)  // kWh
  electricityAmount Float     @default(0)
  waterAmount       Float     @default(0)
  serviceAmount     Float     @default(0)
  otherAmount       Float     @default(0)
  totalAmount       Float
  description       String?
  dueDate           DateTime?
  paidDate          DateTime?
  status            String    @default("UNPAID")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([tenantId, month, year])
  @@index([tenantId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  message   String
  isRead    Boolean  @default(false)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  
  @@index([tenantId])
  @@index([isRead])
}

model MaintenanceRequest {
  id          String   @id @default(cuid())
  tenantId    String
  roomId      String
  title       String
  description String
  priority    String   @default("MEDIUM")
  status      String   @default("PENDING")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  room        Room     @relation(fields: [roomId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId])
  @@index([roomId])
  @@index([status])
}

model Post {
  id         String    @id @default(cuid())
  authorId   String
  authorType String    // 'LANDLORD' or 'TENANT'
  content    String
  images     String    @default("[]") // JSON array of image URLs
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes      Like[]
  comments   Comment[]
  shares     Share[]
  
  @@index([authorId])
  @@index([createdAt])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  
  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Share {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  sharedWith String?  // 'facebook', 'twitter', 'link', etc.
  createdAt  DateTime @default(now())
  
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([userId])
}

model AnalyticsCache {
  id         String   @id @default(cuid())
  landlordId String
  cacheKey   String   @unique
  data       String   // JSON
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  
  @@index([landlordId])
  @@index([expiresAt])
}

model AnalyticsAuditLog {
  id           String   @id @default(cuid())
  landlordId   String
  action       String   // 'get_overview', 'predict_revenue', etc.
  parameters   String   // JSON
  responseTime Int      // milliseconds
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())
  
  @@index([landlordId])
  @@index([createdAt])
}
